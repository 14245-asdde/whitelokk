rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== USERS ====================
    match /users/{userId} {
      // Читать профиль может любой (для публичных профилей)
      allow read: if true;
      // Создавать профиль может только авторизованный пользователь для себя
      allow create: if request.auth != null && request.auth.uid == userId;
      // Обновлять может только сам пользователь
      allow update: if request.auth != null && request.auth.uid == userId;
      // Удалять только сам пользователь
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ==================== INVITES ====================
    match /invites/{inviteCode} {
      // Читать инвайт может: создатель, получатель или неавторизованный (для проверки при регистрации)
      allow read: if true;
      // Создавать может авторизованный пользователь
      allow create: if request.auth != null;
      // Обновлять может: создатель (для пометки как использованного) или любой авторизованный (при регистрации)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        // При регистрации - помечаем как использованный
        (resource.data.used == false && request.resource.data.used == true)
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // ==================== CUSTOM BADGES ====================
    match /customBadges/{badgeId} {
      // Читать может любой
      allow read: if true;
      // Создавать только авторизованный
      allow create: if request.auth != null;
      // Обновлять только создатель
      allow update: if request.auth != null && request.auth.uid == resource.data.createdBy;
      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }

    // ==================== BADGE KEYS ====================
    match /badgeKeys/{keyId} {
      // Читать может любой авторизованный (для активации)
      allow read: if request.auth != null;
      // Создавать только авторизованный
      allow create: if request.auth != null;
      // Обновлять (пометить как использованный) любой авторизованный
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ==================== VIEW LOGS (антинакрутка) ====================
    match /viewLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // ==================== STATS ====================
    match /stats/{statId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
